# Supabase Configuration (exposed to client)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (server-side only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Supabase password for seed script
SUPABASE_PW=your_supabase_password_here

# Optional: Custom User-Agent for external API calls (default: MTGDeckBuilder/1.0)
VITE_USER_AGENT=MTGDeckBuilder/1.0

# Optional: Cache TTL values (in milliseconds)
# CACHE_TTL_EDHREC: How long to cache EDHREC suggestions (default: 86400000 = 24 hours)
CACHE_TTL_EDHREC=86400000

# CACHE_TTL_TOURNAMENT: How long to cache tournament results (default: 21600000 = 6 hours)
CACHE_TTL_TOURNAMENT=21600000

# Optional: Frontend URL for CORS origin checking (default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173
